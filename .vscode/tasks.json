{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Wails: Build Clean",
      "type": "shell",
      "command": "wails",
      "args": ["build", "-clean"],
      "options": {
        "cwd": "${workspaceFolder}/cmd/npcgen-wails"
      },
      "group": "build"
    },
    {
      "label": "Wails: Dev",
      "type": "shell",
      "command": "wails",
      "args": ["dev"],
      "options": {
        "cwd": "${workspaceFolder}/cmd/npcgen-wails"
      }
    },
    {
      "label": "Wails: Go Build Manual (desktop,production)",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-tags",
        "desktop,production",
        "-ldflags",
        "-w -s -H windowsgui",
        "-o",
        "build/bin/npcgen-wails-manual.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}/cmd/npcgen-wails"
      },
      "group": "build"
    }
  ]
}
